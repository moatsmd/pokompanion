---
import Base from '../../layouts/Base.astro';
import { habitats } from '../../lib/data';

const biomes = [...new Set(habitats.map((h) => h.biome).filter(Boolean))].sort();
const sorted = [...habitats].sort((a, b) => a.name.localeCompare(b.name));
const pokeList = (h) => (h.attracts ?? []).map((a) => a.pokemon).join(', ');
---

<Base title="Habitats — Pokompanion" active="habitats" description="How to build every Pokémon Pokopia habitat — required items and which Pokémon each attracts.">
  <h1>Habitats</h1>
  <p class="lede">Place these items together to attract Pokémon. Search by habitat or by the Pokémon you want.</p>

  <div class="controls">
    <input type="search" id="q" placeholder="Filter by habitat or Pokémon…" aria-label="Filter habitats" />
    <select id="cat" aria-label="Filter by biome">
      <option value="">All biomes</option>
      {biomes.map((b) => <option value={b}>{b}</option>)}
    </select>
    <span class="count-note" id="count">{sorted.length} habitats</span>
  </div>

  <div class="grid" id="list">
    {sorted.map((h) => (
      <a
        class="card"
        href={`/habitats/${h.id}`}
        data-name={`${h.name} ${pokeList(h)}`.toLowerCase()}
        data-cat={h.biome ?? ''}
      >
        <h3>{h.name} {h.biome && <span class="pill sky">{h.biome}</span>}</h3>
        <p>{h.attracts && h.attracts.length ? `Attracts ${pokeList(h)}` : (h.description ?? 'Habitat.')}</p>
      </a>
    ))}
  </div>
  <p class="empty" id="noresults" hidden>No habitats match your filter.</p>

  <script is:inline>
    (() => {
      const q = document.getElementById('q');
      const cat = document.getElementById('cat');
      const cards = [...document.querySelectorAll('#list .card')];
      const count = document.getElementById('count');
      const none = document.getElementById('noresults');
      function apply() {
        const term = q.value.trim().toLowerCase();
        const c = cat.value;
        let shown = 0;
        for (const el of cards) {
          const ok = (!term || el.dataset.name.includes(term)) && (!c || el.dataset.cat === c);
          el.hidden = !ok;
          if (ok) shown++;
        }
        count.textContent = shown + ' habitat' + (shown === 1 ? '' : 's');
        none.hidden = shown !== 0;
      }
      q.addEventListener('input', apply);
      cat.addEventListener('change', apply);
    })();
  </script>
</Base>
