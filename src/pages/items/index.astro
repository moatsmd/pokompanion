---
import Base from '../../layouts/Base.astro';
import { items } from '../../lib/data';

const categories = [...new Set(items.map((i) => i.category).filter(Boolean))].sort();
const sorted = [...items].sort((a, b) => a.name.localeCompare(b.name));
---

<Base title="Items — Pokompanion" active="items" description="Furniture, decor, kits, food and collectibles in Pokémon Pokopia.">
  <h1>Items</h1>
  <p class="lede">Furniture, decor, building kits, food and collectibles.</p>

  <div class="controls">
    <input type="search" id="q" placeholder="Filter items…" aria-label="Filter items" />
    <select id="cat" aria-label="Filter by category">
      <option value="">All categories</option>
      {categories.map((c) => <option value={c}>{c}</option>)}
    </select>
    <span class="count-note" id="count">{sorted.length} items</span>
  </div>

  <div class="grid" id="list" data-noun="item">
    {sorted.map((it) => (
      <a class="card" href={`/items/${it.id}`} data-name={it.name.toLowerCase()} data-cat={it.category ?? ''}>
        <h3>{it.name} {it.category && <span class="pill clay">{it.category}</span>}</h3>
        <p>{it.description ?? (it.obtain ? `Obtain: ${it.obtain}.` : 'Item.')}</p>
      </a>
    ))}
  </div>
  <p class="empty" id="noresults" hidden>No items match your filter.</p>

  <script is:inline src="/browse.js"></script>
</Base>
